#
#   # good
#   class MyClass # lib/foo/bar.rb
#     FOO = 'bar'
#   end
#
# @example when in a `spec/support/` file
#   # good
#   FOO = 'bar' # spec/support/foo/bar.rb
#
# @example when in a `config/` file
