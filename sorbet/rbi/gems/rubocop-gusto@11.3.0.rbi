#   end
#
#   # good
#   RSpec.describe Payments::Processor do
#     describe Payments::Processor::Worker do
#     end
#   end
#
#   # good - `RSpec.describe self` resolves to the enclosing namespace
#   module Payments
#     RSpec.describe self do
